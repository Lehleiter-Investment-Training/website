<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
<title>{{ pageTitle | default(site.title) }} | {{ site.author }}</title>
<meta name="description" content="{{ description | default(site.description) }}">
{% if keywords %}
<meta name="keywords" content="{{ keywords }}">
{% endif %}
<meta name="author" content="{{ site.author }}">

{% if ogTitle %}
<!-- Open Graph Tags -->
<meta property="og:title" content="{{ ogTitle | default(pageTitle) }} | {{ site.author }}">
<meta property="og:description" content="{{ ogDescription | default(description) | default(site.description) }}">
<meta property="og:type" content="{{ ogType | default('website') }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:image" content="{{ ogImage | default(site.url + '/assets/images/buchcover.png') }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
{% if ogImageAlt %}
<meta property="og:image:alt" content="{{ ogImageAlt }}">
{% endif %}
<!-- Twitter Card Tags -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle | default(pageTitle) }} | {{ site.author }}">
<meta name="twitter:description" content="{{ ogDescription | default(description) | default(site.description) }}">
<meta name="twitter:image" content="{{ ogImage | default(site.url + '/assets/images/buchcover.png') }}">
{% endif %}

{% if canonical %}
<link rel="canonical" href="{{ canonical }}" />
{% else %}
<link rel="canonical" href="{{ site.url }}{{ page.url }}" />
{% endif %}

<!-- Security Headers -->
<meta http-equiv="X-Content-Type-Options" content="nosniff">
<meta http-equiv="X-Frame-Options" content="SAMEORIGIN">
<meta name="referrer" content="strict-origin-when-cross-origin">

<!-- Favicon -->
<link rel="icon" href="/assets/images/favicon.jpg" type="image/jpeg">
<link rel="apple-touch-icon" href="/assets/images/favicon.jpg">

<!-- Analytics (Plausible - DSGVO-konform, kein Cookie-Consent nötig) -->
<script async src="https://plausible.io/js/pa-T5vA5Qxo17TsscVc7N3IM.js"></script>
<script>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init()</script>

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">

<!-- Stylesheets -->
<link rel="stylesheet" href="/assets/css/variables.css">
<link rel="stylesheet" href="/assets/css/base.css">
<link rel="stylesheet" href="/assets/css/nav.css">
<link rel="stylesheet" href="/assets/css/components.css">
<link rel="stylesheet" href="/assets/css/footer.css">
<link rel="stylesheet" href="/assets/css/cookie.css">
<link rel="stylesheet" href="/assets/css/responsive.css">
{% if extraCss %}
{% for css in extraCss %}
<link rel="stylesheet" href="{{ css }}">
{% endfor %}
{% endif %}